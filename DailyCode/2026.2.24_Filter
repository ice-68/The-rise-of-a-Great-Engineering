   ],
   "id": "6a23490226a1fdc",
   "outputs": [],
   "execution_count": null
  },
  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "###  7. **Query() 可以按条件拿数据**",
   "id": "e6f16a415ac02c8"
  },
  {
   "metadata": {},
   "cell_type": "code",
   "source": [
    "re=df.query('age>30')#.sample(frac =  ...)\n",
    "print(re)\n",
